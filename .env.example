# Telegram
TELEGRAM_BOT_TOKEN=

# Phoenix (perpetuals)
PHOENIX_API_URL=https://perp-api.phoenix.trade
PHOENIX_API_KEY=
PHOENIX_BUILDER_AUTHORITY=
# Builder authority private key (base58). Used to sign Flight-wrapped orders.
PHOENIX_BUILDER_PRIVATE_KEY=

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Database
DATABASE_PATH=./data/phoenix-bot.db

# Crypto (master key for at-rest encryption of any secrets, hex, 32 bytes)
MASTER_ENCRYPTION_KEY=

# Access control (comma-separated telegram user ids; empty = public)
WHITELIST_USER_IDS=

# Limits
RATE_LIMIT_TRADES_PER_MIN=10
MAX_NOTIONAL_USDC=1000
DEFAULT_CONFIRM_TRADES=true

# Logging
LOG_LEVEL=info
NODE_ENV=production
